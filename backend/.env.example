GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_API_KEY=your_google_api_key_for_crux
REDIRECT_URI=http://localhost:3001/api/auth/callback
FRONTEND_URL=http://localhost:5173
PORT=3001

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cwv

# Comma-separated list of GSC sites to scrape nightly
GSC_SITES=https://www.ambitionbox.com/

# Cron schedule (default: midnight server time). Use crontab.guru to customise.
# e.g. "30 18 * * *" = 18:30 UTC = midnight IST
CRON_SCHEDULE=0 0 * * *

# Metabase session token (from browser cookie: metabase.SESSION)
METABASE_SESSION=your_metabase_session_token
